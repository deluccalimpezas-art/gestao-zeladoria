generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Condominio {
  id              String              @id @default(uuid())
  nome            String
  administradora  String?
  cnpj            String?             @unique
  endereco        String?
  created_at      DateTime            @default(now())
  updated_at      DateTime            @updatedAt
  inicio          String?
  termino         String?
  valorContrato   Float?
  valorVerao      Float?
  cargaHoraria    String?
  valorAtivo      String              @default("base")
  deleted         Boolean             @default(false)
  funcionarios    Funcionario[]
  financasMensais MonthlyCondominio[]
}

model Funcionario {
  id                     String               @id @default(uuid())
  nome                   String
  cargo                  String?
  salarioBase            Float                @default(0)
  condominioId           String
  created_at             DateTime             @default(now())
  updated_at             DateTime             @updatedAt
  dataAdmissao           String?
  fimContratoExperiencia String?
  statusClt              String?
  vencimentoFerias       String?
  condominio             Condominio           @relation(fields: [condominioId], references: [id], onDelete: Cascade)
  pagamentos             MonthlyFuncionario[]
}

model FinanceMonth {
  id           String               @id @default(uuid())
  nome         String               @unique
  fechado      Boolean              @default(false)
  created_at   DateTime             @default(now())
  condominios  MonthlyCondominio[]
  funcionarios MonthlyFuncionario[]
  impostos     MonthlyImposto[]
}

model MonthlyCondominio {
  id           String       @id @default(uuid())
  valorCobrado Float
  pago         Boolean      @default(false)
  monthId      String
  condominioId String?
  cnpj         String?
  nome         String
  condominio   Condominio?  @relation(fields: [condominioId], references: [id])
  month        FinanceMonth @relation(fields: [monthId], references: [id], onDelete: Cascade)
}

model MonthlyFuncionario {
  id            String       @id @default(uuid())
  valorPago     Float
  horasExtras   Float        @default(0)
  monthId       String
  funcionarioId String?
  condominio    String?
  nome          String
  salarioBase   Float        @default(0)
  statusClt     String?
  funcionario   Funcionario? @relation(fields: [funcionarioId], references: [id])
  month         FinanceMonth @relation(fields: [monthId], references: [id], onDelete: Cascade)
}

model MonthlyImposto {
  id      String       @id @default(uuid())
  nome    String
  valor   Float
  pago    Boolean      @default(false)
  monthId String
  month   FinanceMonth @relation(fields: [monthId], references: [id], onDelete: Cascade)
}

model WeeklyTask {
  id        String   @id @default(uuid())
  dayOfWeek Int
  title     String
  time      String?
  createdAt DateTime @default(now())
  userId    String   @default("Usuário 1")
}

model CalendarEvent {
  id          String   @id @default(uuid())
  title       String
  date        DateTime
  isPermanent Boolean  @default(false)
  createdAt   DateTime @default(now())
  userId      String   @default("Usuário 1")
}
