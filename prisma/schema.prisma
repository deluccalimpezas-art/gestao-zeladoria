generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Condominio {
  id              String              @id @default(uuid())
  nome            String
  administradora  String?
  cnpj            String?             @unique
  endereco        String?
  created_at      DateTime            @default(now())
  updated_at      DateTime            @updatedAt
  inicio          String?
  termino         String?
  valorContrato   Float?
  valorVerao      Float?
  cargaHoraria    String?
  valorAtivo      String              @default("base")
  deleted         Boolean             @default(false)
  contratoPdf     Bytes?
  contratoNome    String?
  observacao      String?
  funcionarios    Funcionario[]
  financasMensais MonthlyCondominio[]
}

model Funcionario {
  id                     String               @id @default(uuid())
  nome                   String
  cargo                  String?
  salarioBase            Float                @default(0)
  condominioId           String?
  created_at             DateTime             @default(now())
  updated_at             DateTime             @updatedAt
  dataAdmissao           String?
  fimContratoExperiencia String?
  statusClt              String?
  vencimentoFerias       String?
  condominioNome         String?
  condominio             Condominio?           @relation(fields: [condominioId], references: [id], onDelete: Cascade)
  deleted                Boolean             @default(false)
  contratoPdf            Bytes?
  contratoNome           String?
  observacao             String?
  pagamentos             MonthlyFuncionario[]
}

model FinanceMonth {
  id           String               @id @default(uuid())
  nome         String               @unique
  fechado      Boolean              @default(false)
  created_at   DateTime             @default(now())
  condominios  MonthlyCondominio[]
  funcionarios MonthlyFuncionario[]
  impostos     MonthlyImposto[]
  gastos       MonthlyGasto[]
}

model MonthlyCondominio {
  id           String       @id @default(uuid())
  valorCobrado Float
  pago         Boolean      @default(false)
  monthId      String
  condominioId String?
  cnpj         String?
  nome         String
  observacao   String?
  condominio   Condominio?  @relation(fields: [condominioId], references: [id])
  month        FinanceMonth @relation(fields: [monthId], references: [id], onDelete: Cascade)
}

model MonthlyFuncionario {
  id            String       @id @default(uuid())
  valorPago     Float
  horasExtras   Float        @default(0)
  rescisaoFerias Float?      @default(0)
  monthId       String
  funcionarioId String?
  condominio    String?
  nome          String
  salarioBase   Float        @default(0)
  statusClt     String?
  observacao    String?
  funcionario   Funcionario? @relation(fields: [funcionarioId], references: [id])
  month         FinanceMonth @relation(fields: [monthId], references: [id], onDelete: Cascade)
}

model RHImposto {
  id         String   @id @default(uuid())
  nome       String
  valor      Float    @default(0)
  vencimento String?
  observacao String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model MonthlyImposto {
  id      String       @id @default(uuid())
  nome    String
  valor   Float
  pago    Boolean      @default(false)
  observacao String?
  monthId String
  month   FinanceMonth @relation(fields: [monthId], references: [id], onDelete: Cascade)
}

model MonthlyGasto {
  id        String       @id @default(uuid())
  descricao String
  valor     Float
  pago      Boolean      @default(false)
  categoria String?      // Pagamentos, Vales, Restaurantes, Outros
  data      String?      // YYYY-MM-DD
  monthId   String
  month     FinanceMonth @relation(fields: [monthId], references: [id], onDelete: Cascade)
}

model WeeklyTask {
  id        String   @id @default(uuid())
  dayOfWeek Int
  title     String
  time      String?
  createdAt DateTime @default(now())
  userId    String   @default("Usuário 1")
}

model CalendarEvent {
  id          String   @id @default(uuid())
  title       String
  date        DateTime
  isPermanent Boolean  @default(false)
  createdAt   DateTime @default(now())
  userId      String   @default("Usuário 1")
}

model Gasto {
  id          String   @id @default(uuid())
  descricao   String
  valor       Float
  categoria   String?
  data        DateTime @default(now())
  formaPagto  String?
  observacao  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PersonalFinanceMonth {
  id            String                      @id @default(uuid())
  monthName     String                      // Ex: "Março 2024"
  year          Int
  month         Int                         // 1-12
  fixedExpenses PersonalFixedExpense[]
  cardExpenses  PersonalCreditCardExpense[]

  @@unique([month, year])
}

model PersonalFixedExpense {
  id      String               @id @default(uuid())
  name    String               // Luz, Agua, Aluguel, Seguro, Carro, Dentista, Seanet
  value   Float
  dueDate Int?                 // Dia de pagamento
  paid    Boolean              @default(false)
  monthId String
  month   PersonalFinanceMonth @relation(fields: [monthId], references: [id], onDelete: Cascade)
}

model PersonalCreditCard {
  id        String   @id @default(uuid())
  name      String   @unique
  bank      String?
  color     String?  // Para flair na UI
  createdAt DateTime @default(now())
  expenses  PersonalCreditCardExpense[]
}

model PersonalCreditCardExpense {
  id                 String               @id @default(uuid())
  cardId             String?              // Novo link opcional por enquanto
  cardName           String               @default("Principal") 
  description        String
  value              Float
  isInstallment      Boolean              @default(false)
  currentInstallment Int?
  totalInstallments  Int?
  installmentGroupId String?
  category           String?              // mercado, restaurante, gasolina, outros
  paid               Boolean              @default(false)
  monthId            String
  month              PersonalFinanceMonth @relation(fields: [monthId], references: [id], onDelete: Cascade)
  card               PersonalCreditCard?  @relation(fields: [cardId], references: [id])
}

model PosObra {
  id              String         @id @default(uuid())
  nome            String
  cliente         String?
  data            String?        // Mês de Recebimento (YYYY-MM ou string)
  valor           Float?         // Preço
  status          String         @default("Em Andamento") // Em Andamento, Concluído
  gastos          PosObraGasto[]
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt
}

model PosObraGasto {
  id          String   @id @default(uuid())
  descricao   String
  valor       Float
  tipo        String   // Salário, Produto
  data        String?  // YYYY-MM-DD
  posObraId   String
  posObra     PosObra  @relation(fields: [posObraId], references: [id], onDelete: Cascade)
}

model TaskTodo {
  id          String   @id @default(uuid())
  title       String
  description String?
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Note {
  id        String   @id @default(uuid())
  title     String
  content   String?  @db.Text
  color     String?  @default("slate")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

